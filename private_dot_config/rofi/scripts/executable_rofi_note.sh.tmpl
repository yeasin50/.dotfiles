#!/bin/bash

# 1. Setup paths
INBOX_DIR="$HOME/github/writings"
TEMPLATE_DIR="$HOME/github/writings/templates"

mkdir -p "$INBOX_DIR"
mkdir -p "$TEMPLATE_DIR"

# 2. Get existing notes (flat)
matches=$(find "$INBOX_DIR" -maxdepth 1 -type f -name "*.md" -exec basename {} .md \;)

# 3. Primary Rofi menu: Search or type new note name
note_choice=$(echo -e "$matches" | rofi -dmenu -i -p "Note:" -lines 10)
[[ -z "$note_choice" ]] && exit 0

FILE_PATH="$INBOX_DIR/${note_choice}.md"

# 4. If the note is NEW, ask for a template
if [[ ! -f "$FILE_PATH" ]]; then
    # Get list of templates from the template folder
    template_list=$(find "$TEMPLATE_DIR" -maxdepth 1 -type f -name "*.md" -exec basename {} \;)

    if [[ -n "$template_list" ]]; then
        # Prompt to select a template (with an option for 'None')
        selection=$(echo -e "None\n$template_list" | rofi -dmenu -i -p "Select Template:" -lines 5)
        
        if [[ "$selection" != "None" && -n "$selection" ]]; then
            # Copy the template content to the new file
            cp "$TEMPLATE_DIR/$selection" "$FILE_PATH"
            # Optional: Replace a placeholder like {{title}} with the note name
            sed -i "s/{{title}}/$note_choice/g" "$FILE_PATH"
        else
            # If 'None' or Esc, just create a blank file with a title
            echo "# $note_choice" > "$FILE_PATH"
        fi
    else
        # No templates found in the folder, default to basic header
        echo "# $note_choice" > "$FILE_PATH"
    fi
fi

# 5. Open in Kitty/Neovim
kitty -- nvim "$FILE_PATH"
