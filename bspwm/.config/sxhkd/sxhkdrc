# Mod key
super + ...   (already default Mod4 in sxhkd/bspwm)


# making capslock to esc for nvim  motion ; uum doesn't work
setxkbmap -option caps:escape

super + Return
    wezterm --config-file ~/.config/wezterm/wezterm.lua

# --- Launcher & Switcher ---
super + space
    rofi -show drun -show-icons

super + Tab
    rofi -show window

# --- Basic controls ---
super + shift + q
    bspc node -c

# restart bspwm
super + shift + r
    bspc wm -r && pkill -USR1 -x sxhkd


super + f 
    xdg-open . 

super + b
    /usr/bin/flatpak run --branch=stable --arch=x86_64 --command=launch-script.sh app.zen_browser.zen

super + k
    /home/yeasin/apps/kdenlive-26.04.0-x86_64.AppImage

# Screenshot select area
super + shift + s 
    flameshot gui

# Emoji picker
ctrl + period
    /usr/bin/flatpak run --branch=stable --arch=x86_64 --command=emoji-mart io.github.vemonet.EmojiMart


## Keyboard volume nob
XF86AudioRaiseVolume
    pactl set-sink-volume @DEFAULT_SINK@ +5%
XF86AudioLowerVolume
    pactl set-sink-volume @DEFAULT_SINK@ -5%
XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

# --- Focus movement  ---
super + Left
    bspc node -f west

super + Down
    bspc node -f south

super + Up
    bspc node -f north

super + Right
    bspc node -f east

# --- Move window (like sway move container) ---
super + shift + Left
    bspc node -s west

super + shift + Right
    bspc node -s east

super + shift + Up
    bspc node -s north

super + shift + Down
    bspc node -s south

# --- Workspaces ---
super + 1
    bspc desktop -f 1

super + 2
    bspc desktop -f 2

super + 3
    bspc desktop -f 3

super + 4
    bspc desktop -f 4

super + 5
    bspc desktop -f 5

super + 6
    bspc desktop -f 6

# --- Move window to workspace ---
super + shift + 1
    bspc node -d 1

super + shift + 2
    bspc node -d 2

super + shift + 3
    bspc node -d 3

super + shift + 4
    bspc node -d 4

super + shift + 5
    bspc node -d 5

super + shift + 6
    bspc node -d 6
