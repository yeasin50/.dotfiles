# ~/.bashrc_env 


export PATH="$PATH:$HOME/fvm/default/bin"
export PATH="$PATH:$HOME/fvm/default/bin/cache/dart-sdk/bin"

export PATH="$PATH:$HOME/apps/flutter/bin"
export PATH="$PATH:$HOME/apps/flutter/bin/cache/dart-sdk/bin"

export PATH="$PATH":"$HOME/.pub-cache/bin"
export PATH="$PATH":"$HOME/apps/go/bin"
export PATH="$HOME/go/bin:$PATH"
export PATH="$PATH:$HOME/go/bin"

export ANDROID_SDK_ROOT=/mnt/debian_stuffs/android_studio_install
export PATH=$PATH:$ANDROID_SDK_ROOT/cmdline-tools/latest/bin
export PATH=$PATH:$ANDROID_SDK_ROOT/emulator
export PATH=$PATH:$ANDROID_SDK_ROOT/platform-tools
export LV2_PATH=$HOME/.lv2:/usr/lib/lv2:/usr/local/lib/lv2

export ANDROID_AVD_HOME=/mnt/debian_stuffs/android_avds
export PATH=$ANDROID_HOME/platform-tools:$ANDROID_HOME/emulator:$PATH

export GRADLE_USER_HOME=/mnt/debian_stuffs/.gradle
export GRADLE_HOME=/mnt/debian_stuffs/gradle
export PATH=$GRADLE_HOME/bin:$PATH
export PATH=$HOME/.local/bin:$PATH
